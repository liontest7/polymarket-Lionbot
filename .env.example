# ═══════════════════════════════════════════════════════════
#  POLYMARKET BOT v4.1 PRO — CONFIGURATION
#  Copy this to .env and fill in your values.
#  NEVER share or commit .env — it contains private keys.
# ═══════════════════════════════════════════════════════════

# ── POLYMARKET API ──────────────────────────────────────────
# Get from: https://polymarket.com → Profile → API Keys
# Leave as-is for PAPER mode — only needed for LIVE mode
POLYMARKET_PK=0xYOUR_PRIVATE_KEY_HERE
POLYMARKET_API_KEY=your-api-key-here
POLYMARKET_API_SECRET=your-api-secret-here
POLYMARKET_API_PASSPHRASE=your-passphrase-here

# ── ALCHEMY (Polygon RPC) ───────────────────────────────────
# Free at: https://alchemy.com → Create App → Polygon Mainnet
ALCHEMY_API_KEY=your-alchemy-key-here

# ── TRADING MODE ────────────────────────────────────────────
# "paper" = demo, no real money (START HERE)
# "live"  = real money — only after validating paper performance
TRADING_MODE=paper

# ── CAPITAL & RISK ──────────────────────────────────────────
CAPITAL_USD=100
MAX_POSITION_PCT=0.08
DAILY_LOSS_LIMIT_PCT=0.05
MAX_TRADES_PER_DAY=50
MAX_CONSECUTIVE_LOSSES=5
COOLDOWN_SECONDS=30

# ── SIGNAL THRESHOLDS ───────────────────────────────────────
# Entry is allowed ANY TIME (not only last 25s) when these are met:
MIN_BTC_DELTA_PCT=0.04
MIN_VELOCITY_PCT_PER_SEC=0.0015
MIN_EDGE_AFTER_FEES=0.025
MIN_SECONDS_REMAINING=10

# ── EXIT MANAGEMENT ─────────────────────────────────────────
# TP: take profit when token price rises by this (e.g. 0.12 = +12 cents)
# SL: stop loss when token price falls by this (e.g. 0.08 = -8 cents)
# TIME_STOP: force exit after this many seconds if no TP/SL hit
TP_TOKEN_GAIN=0.12
SL_TOKEN_LOSS=0.08
TIME_STOP_SECONDS=120

# ── FEES (Polymarket 2026) ──────────────────────────────────
TAKER_FEE_PCT=0.0156
MAKER_FEE_PCT=0.0

# ── LOGGING ─────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
