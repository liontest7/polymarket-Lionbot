# ═══════════════════════════════════════════════════════════
#  POLYMARKET BOT v4.2 PRO — CONFIGURATION
# ═══════════════════════════════════════════════════════════

# ── POLYMARKET API ──────────────────────────────────────────
POLYMARKET_PK=0xYOUR_PRIVATE_KEY_HERE
POLYMARKET_API_KEY=your-api-key-here
POLYMARKET_API_SECRET=your-api-secret-here
POLYMARKET_API_PASSPHRASE=your-passphrase-here

# ── ALCHEMY (Polygon RPC) ───────────────────────────────────
ALCHEMY_API_KEY=your-alchemy-key-here

# ── TRADING MODE ────────────────────────────────────────────
TRADING_MODE=paper

# ── CAPITAL & RISK ──────────────────────────────────────────
CAPITAL_USD=100
MAX_POSITION_PCT=0.08
DAILY_LOSS_LIMIT_PCT=0.06
MAX_TRADES_PER_DAY=50
MAX_OPEN_TRADES=5
MAX_CONSECUTIVE_LOSSES=5
COOLDOWN_SECONDS=20

# ── SIGNAL THRESHOLDS ───────────────────────────────────────
MIN_BTC_DELTA_PCT=0.04
MIN_VELOCITY_PCT_PER_SEC=0.0015
MIN_EDGE_AFTER_FEES=0.04
MIN_SECONDS_REMAINING=10

# ── TOKEN PRICE FILTER (controls payout ratio) ──────────────
# Only buy tokens BELOW max_token_price — underpriced = high payout
# token @ 0.30 → WIN pays +233% | token @ 0.55 → WIN pays +82%
MAX_TOKEN_PRICE=0.55
MIN_TOKEN_PRICE=0.08
PREFERRED_TOKEN_MAX=0.45

# ── EXIT MANAGEMENT ─────────────────────────────────────────
TP_TOKEN_GAIN=0.20
SL_TOKEN_LOSS=0.10
TIME_STOP_SECONDS=260

# ── FEES ────────────────────────────────────────────────────
TAKER_FEE_PCT=0.0156
MAKER_FEE_PCT=0.0

# ── LOGGING ─────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
